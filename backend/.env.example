# ── 数据库 ───────────────────────────────────────────────────
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="CorvusNote"

# ── JWT ──────────────────────────────────────────────────────
# 用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成
SECRET_KEY="在此填入强随机密钥，≥32字符"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 天

# ── CORS（逗号分隔，精确匹配前端域名，禁止使用 * ）──────────
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:3000"

# ── 文件存储 ─────────────────────────────────────────────────
UPLOAD_DIR="./uploads"

# ── DashScope API Key ────────────────────────────────────────
# 从 https://dashscope.aliyuncs.com/ 获取，绝对不要提交真实 Key
DASHSCOPE_API_KEY="sk-在此填入你的DashScope密钥"
